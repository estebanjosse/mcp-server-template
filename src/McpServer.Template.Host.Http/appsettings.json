{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ModelContextProtocol": "Debug"
    }
  },
  "Authentication": {
    "Mode": "simple",
    "ApiKeys": [
      "new-key-at-least-32-characters-long-here",
      "old-key-at-least-32-characters-long-here"
    ]
  },
  "Metrics": {
    "Enabled": false
  },
  "AllowedHosts": "*",
  "McpServer": {
    "Name": "McpServer.Template",
    "Version": "1.0.0",
    "Description": "A clean, scalable MCP server template with .NET 10"
  }
}
